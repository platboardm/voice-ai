{
  "stt": {
    "preservePrefix": "microphone.",
    "parameters": [
      {
        "key": "listen.region",
        "label": "Region",
        "type": "input",
        "required": false
      },
      {
        "key": "listen.model",
        "label": "Model",
        "type": "input",
        "required": false
      },
      {
        "key": "listen.language",
        "label": "Language",
        "type": "input",
        "required": false
      },
      {
        "key": "listen.threshold",
        "label": "Transcript Confidence Threshold",
        "type": "slider",
        "required": false,
        "default": "0.5",
        "min": 0.1,
        "max": 0.9,
        "step": 0.1,
        "helpText": "Transcripts with a confidence score below this threshold will be filtered out."
      }
    ]
  }
}
